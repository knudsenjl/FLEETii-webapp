# Kopiér denne fil til ".env" og udfyld med værdierne fra dit Supabase-projekt
# (Project Settings → API).
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=din-anon-public-key

# Vælger datakilde for køretøjs-/GPS-data ("mock" | "live"). Udeladt eller
# tom værdi = "mock" (dagens statiske 2hire-testdata under src/data/mock).
# "live" kræver en implementeret liveVehicleDataSource og er IKKE klar endnu.
VITE_DATA_SOURCE=mock

# Kun til Netlify Functions (netlify/functions) — bruges ALDRIG i klientkoden.
# Sæt disse i Netlify (Site settings → Environment variables), ikke kun lokalt,
# og giv dem ALDRIG et VITE_-præfiks, ellers bliver den hemmelige nøgle bundlet
# ind i klienten.
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=din-service-role-key

# Bruges af netlify/functions/send-vehicle-request.mts til at sende mail via
# Resend (https://resend.com — gratis op til 3.000 mails/md). Find nøglen
# under API Keys i Resend-dashboardet.
RESEND_API_KEY=din-resend-api-key

# Modtager af mailen sendt fra "Send bestilling til FLEETii" (NewVehiclePage).
# Skal være Resend-kontoens egen e-mail, indtil et domæne er verificeret
# (se RESEND_FROM nedenfor).
RESEND_MAIL_RECIEVER=din-modtager@example.com

# Valgfri: afsenderadresse. Udeladt = Resends delte test-domæne
# ("FLEETii <onboarding@resend.dev>"), som kun kan sende til den e-mail der
# ejer Resend-kontoen. Sæt denne til en adresse på et verificeret domæne
# (Resend → Domains → Add Domain) for at kunne sende til alle modtagere,
# f.eks. "FLEETii <noreply@mh3.dk>".
RESEND_FROM=FLEETii <onboarding@resend.dev>

# 2hire developer portal (https://developer.2hire.io) — bruges af
# "test data/2hire test environment.py" til at autentificere mod
# 2hire's test/e2e API.
TWOHIRE_CLIENT_ID=din-2hire-client-id
TWOHIRE_CLIENT_SECRET=din-2hire-client-secret
