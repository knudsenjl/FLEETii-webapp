# Kopiér denne fil til ".env" og udfyld med værdierne fra dit Supabase-projekt
# (Project Settings → API).
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=din-anon-public-key

# Vælger datakilde for køretøjs-/GPS-data. Udeladt eller tom værdi =
# "mockup-data". Læses BÅDE af klienten (getVehicleDataSource()) og af
# Netlify Functions (twoHireClient.ts, samme værdi vælger test- eller
# produktions-host hos 2hire) — så dette er den ene, samlede kontakt for
# hvilken datakilde/miljø der bruges, i stedet for to separate variabler.
#   "mockup-data"               statiske 2hire-testdata under src/data/mock (ingen DB-adgang krævet).
#   "2hire-test-adaptor"        køretøjsdata fra Supabase (vehicle_profiles/vehicle_signals,
#                               se supabase/seed_vehicle_profiles.sql og seed_vehicle_signals.sql),
#                               2hire-webhook/-abonnement mod test-miljøet (test.adapter.2hire.io).
#   "2hire-production-adaptor"  samme som ovenfor, men mod 2hire's rigtige flåde (adapter.2hire.io).
VITE_DATA_SOURCE=mockup-data

# Link til brugermanualen. Vises som "Brugermanual"-knappen på AboutPage.tsx
# (/about) og linkes til i create-user.mts's velkomstmail til nye brugere.
# Ikke hemmelig — VITE_-præfikset er bevidst her, så både klienten og
# Netlify Functions kan læse den samme værdi uden duplikering (Netlify
# Functions kan læse enhver VITE_-variabel via process.env ligesom
# VITE_SUPABASE_URL allerede gør andre steder i dette repo). Udeladt =
# "Brugermanual"-knappen skjules på AboutPage, og velkomstmailen udelader
# den sætning.
VITE_BRUGERMANUAL_URL=https://din-brugermanual-url

# Kun til Netlify Functions (netlify/functions) — bruges ALDRIG i klientkoden.
# Sæt disse i Netlify (Site settings → Environment variables), ikke kun lokalt,
# og giv dem ALDRIG et VITE_-præfiks, ellers bliver den hemmelige nøgle bundlet
# ind i klienten.
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=din-service-role-key

# Delt adgangskode nye brugere oprettes med (se create-user.mts) — de bliver
# tvunget til at vælge deres egen på SetPasswordPage.tsx ved første login, så
# denne behøver ikke være hemmelig i den forstand at den beskytter noget på
# længere sigt, men den bør IKKE være et almindeligt/gættet ord: hvis
# "Leaked password protection" nogensinde slås til i Supabase Auth, vil et
# password fundet i kendte databrud blive afvist af Supabase selv.
DEFAULT_USER_PASSWORD=en-unik-midlertidig-adgangskode

# Bruges af netlify/functions/send-vehicle-request.mts OG create-user.mts
# (nye brugeres velkomstmail) til at sende mail via Resend
# (https://resend.com — gratis op til 3.000 mails/md). Find nøglen under API
# Keys i Resend-dashboardet. Ignoreres helt hvis SMTP_HOST er sat (se
# nedenfor) — så bruges almindelig SMTP i stedet.
#
# VIGTIGT for create-user.mts's velkomstmail: uden et verificeret domæne
# (se RESEND_FROM nedenfor) kan Resend KUN levere til Resend-kontoens egen
# e-mail — modsat send-vehicle-request.mts (hvor modtageren altid er
# RESEND_MAIL_RECIEVER, typisk kontoens egen adresse), går create-user.mts's
# mail til den nyoprettede brugers egen adresse, som næsten aldrig er
# kontoens egen. Sæt enten SMTP_HOST, eller verificér et domæne i Resend,
# ellers vil velkomstmailen fejle for stort set alle nye brugere (kontoen
# oprettes stadig fint — kun mailen fejler, se emailSent i svaret).
RESEND_API_KEY=din-resend-api-key

# Modtager af mailen sendt fra "Send bestilling til FLEETii" (NewVehiclePage).
# Bruges uanset om der sendes via Resend eller SMTP. Ved Resend uden
# verificeret domæne skal denne være Resend-kontoens egen e-mail (se
# RESEND_FROM nedenfor).
RESEND_MAIL_RECIEVER=din-modtager@example.com

# Valgfri: afsenderadresse ved Resend. Udeladt = Resends delte test-domæne
# ("FLEETii <onboarding@resend.dev>"), som kun kan sende til den e-mail der
# ejer Resend-kontoen. Sæt denne til en adresse på et verificeret domæne
# (Resend → Domains → Add Domain) for at kunne sende til alle modtagere,
# f.eks. "FLEETii <noreply@mh3.dk>".
RESEND_FROM=FLEETii <onboarding@resend.dev>

# Alternativ til Resend, mens et domæne afventer DNS-verificering: sæt
# SMTP_HOST (+ SMTP_USER/SMTP_PASS nedenfor) for at sende BÅDE
# send-vehicle-request.mts's OG create-user.mts's mail via almindelig SMTP i
# stedet — f.eks. Office 365 ("smtp.office365.com", port 587) med en rigtig
# postkasses login. RESEND_API_KEY/RESEND_FROM ignoreres helt når denne er
# sat.
SMTP_HOST=smtp.office365.com

# Påkrævet når SMTP_HOST er sat — login til SMTP-serveren (for Office 365:
# en rigtig postkasses adresse og adgangskode/app-adgangskode).
SMTP_USER=din-postkasse@example.com
SMTP_PASS=din-smtp-adgangskode

# Valgfri: SMTP-port (default 587, STARTTLS). Sæt til 465 for implicit TLS.
SMTP_PORT=587

# Valgfri: afsenderadresse ved SMTP. Udeladt = SMTP_USER.
SMTP_FROM=FLEETii <din-postkasse@example.com>

# 2hire developer portal (https://developer.2hire.io) — bruges af
# netlify/functions/_shared/twoHireClient.ts til at autentificere mod 2hire's
# Adapter API.
TWOHIRE_CLIENT_ID=din-2hire-client-id
TWOHIRE_CLIENT_SECRET=din-2hire-client-secret

# Fælles hemmelighed som 2hire signerer webhook-beskeder med (X-Hub-Signature,
# se netlify/functions/2hire-webhook.mts). Generér en lang, tilfældig streng;
# sæt PRÆCIS den samme værdi her, og send den med når
# netlify/functions/2hire-subscribe.mts kaldes.
TWOHIRE_WEBHOOK_SECRET=en-lang-tilfaeldig-hemmelighed
