# Kopiér denne fil til ".env" og udfyld med værdierne fra dit Supabase-projekt
# (Project Settings → API).
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=din-anon-public-key

# Kun til Netlify Functions (netlify/functions) — bruges ALDRIG i klientkoden.
# Sæt disse i Netlify (Site settings → Environment variables), ikke kun lokalt,
# og giv dem ALDRIG et VITE_-præfiks, ellers bliver den hemmelige nøgle bundlet
# ind i klienten.
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=din-service-role-key
